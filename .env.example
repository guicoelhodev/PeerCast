# Create this key in the Tailscale admin console. Never commit a real key.
TAILSCALE_AUTHKEY=tskey-auth-replace-with-your-key

# HTTPS MagicDNS address for the fixed Tailscale hostname: streaming-open.
# Example: https://streaming-open.example.ts.net
PUBLIC_APP_URL=https://streaming-open.example.ts.net
